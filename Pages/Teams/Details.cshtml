@page
@model Mission10_Thurman.Pages.Teams.DetailsModel

<section class="py-3">
    <div class="container">
        <a asp-page="/Teams/Index" class="btn btn-link">&larr; Back to Teams</a>

        <h2>Team Details</h2>

        @if (Model.Team == null)
        {
            <div class="alert alert-warning">Team not found.</div>
        }
        else
        {
            <dl class="row">
                <dt class="col-sm-2">Team ID</dt>
                <dd class="col-sm-10">@Model.Team.TeamID</dd>

                <dt class="col-sm-2">Team Name</dt>
                <dd class="col-sm-10">@Model.Team.TeamName</dd>
            </dl>

            <h3>Bowlers</h3>

            @if (Model.Bowlers?.Count == 0)
            {
                <p>No bowlers assigned to this team.</p>
            }
            else
            {
                <table class="table table-bordered table-sm">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>City</th>
                            <th>State</th>
                            <th>Phone</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var b in Model.Bowlers)
                        {
                            <tr>
                                <td>@(b.BowlerFirstName) @(b.BowlerMiddleInit) @(b.BowlerLastName)</td>
                                <td>@b.BowlerCity</td>
                                <td>@b.BowlerState</td>
                                <td>@b.BowlerPhoneNumber</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        }
    </div>
</section>